      "id": "send-welcome-back",
      "name": "Send Welcome Back",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [700, 150],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO users (telegram_id, username, first_name, onboarding_step)\nVALUES ($1, $2, $3, 'ask_name')\nON CONFLICT (telegram_id) DO UPDATE SET username=EXCLUDED.username, updated_at=now()\nRETURNING id, telegram_id, first_name, onboarding_step",
        "additionalFields": { "queryParams": "={{ [$('Telegram Trigger').item.json.message.from.id, $('Telegram Trigger').item.json.message.from.username || '', $('Telegram Trigger').item.json.message.from.first_name || 'Friend'].join(',') }}" }
      },
      "id": "upsert-user",
      "name": "Upsert User",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [700, 400],
      "credentials": { "postgres": { "id": "REPLACE_POSTGRES_CRED_ID", "name": "FitBuddy DB" } }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO conversation_state (user_id, flow_id, step, context)\nVALUES ($1, 'onboarding', 'ask_name', '{}')\nON CONFLICT (user_id, flow_id) DO UPDATE SET updated_at=now()\nRETURNING id, step, context",
        "additionalFields": { "queryParams": "={{ $json.id }}" }
      },
      "id": "get-conv-state",
      "name": "Get Conv State",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [900, 400],
      "credentials": { "postgres": { "id": "REPLACE_POSTGRES_CRED_ID", "name": "FitBuddy DB" } }
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.step }}",
        "rules": {
          "rules": [
            { "value2": "ask_name", "output": 0 },
            { "value2": "ask_age", "output": 1 },
            { "value2": "ask_gender", "output": 2 },
            { "value2": "ask_height", "output": 3 },
            { "value2": "ask_weight", "output": 4 },
            { "value2": "ask_activity", "output": 5 },
            { "value2": "ask_goal", "output": 6 }
          ]
        },
        "fallbackOutput": 7
      },
      "id": "switch-step",
      "name": "Switch on Step",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [1100, 400]
    },
    {
