        "additionalFields": {
          "queryParams": "={{ [\n  $('Process Response & Advance Step').item.json.context.name,\n  $('Process Response & Advance Step').item.json.context.age,\n  $('Process Response & Advance Step').item.json.context.gender,\n  $('Process Response & Advance Step').item.json.context.height_cm,\n  $('Process Response & Advance Step').item.json.context.weight_kg,\n  $('Process Response & Advance Step').item.json.context.activity_level,\n  $('Process Response & Advance Step').item.json.context.goal,\n  $('Process Response & Advance Step').item.json.context.daily_calorie_target,\n  $('Process Response & Advance Step').item.json.userId\n].join(',') }}"
        }
