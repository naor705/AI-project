    {
      "parameters": {
        "jsCode": "// Parse the incoming message to update conversation state\nconst triggerData = $('Telegram Trigger').item.json;\nconst convState = $('Get or Create Conv State').item.json;\nconst userRow = $('Upsert User').item.json;\n\nconst messageText = triggerData.message?.text || '';\nconst callbackData = triggerData.callback_query?.data || '';\nconst inputValue = messageText || callbackData;\n\nconst step = convState.step;\nlet context = {};\ntry { context = typeof convState.context === 'string' ? JSON.parse(convState.context) : (convState.context || {}); } catch(e) { context = {}; }\n\nconst stepMap = {\n  ask_name:     { key: 'name',           next: 'ask_age' },\n  ask_age:      { key: 'age',            next: 'ask_gender' },\n  ask_gender:   { key: 'gender',         next: 'ask_height', transform: v => v.replace('gender_', '') },\n  ask_height:   { key: 'height_cm',      next: 'ask_weight', transform: v => parseFloat(v) },\n  ask_weight:   { key: 'weight_kg',      next: 'ask_activity', transform: v => parseFloat(v) },\n  ask_activity: { key: 'activity_level', next: 'ask_goal', transform: v => v.replace('activity_', '') },\n  ask_goal:     { key: 'goal',           next: 'complete', transform: v => v.replace('goal_', '') }\n};\n\nconst currentStep = stepMap[step];\nif (currentStep) {\n  const rawValue = inputValue.trim();\n  const value = currentStep.transform ? currentStep.transform(rawValue) : rawValue;\n  context[currentStep.key] = value;\n}\n\n// Calculate TDEE if we have all data\nlet dailyCalorieTarget = null;\nif (context.weight_kg && context.height_cm && context.age && context.gender && context.activity_level && context.goal) {\n  // Mifflin-St Jeor BMR\n  let bmr;\n  if (context.gender === 'male') {\n    bmr = 10 * context.weight_kg + 6.25 * context.height_cm - 5 * context.age + 5;\n  } else {\n    bmr = 10 * context.weight_kg + 6.25 * context.height_cm - 5 * context.age - 161;\n  }\n  const multipliers = { sedentary: 1.2, light: 1.375, moderate: 1.55, active: 1.725, very_active: 1.9 };\n  const tdee = bmr * (multipliers[context.activity_level] || 1.2);\n  const goalOffset = { toning: -400, mass: 300, maintenance: 0 };\n  dailyCalorieTarget = Math.round(tdee + (goalOffset[context.goal] || 0));\n  context.daily_calorie_target = dailyCalorieTarget;\n}\n\nconst nextStep = currentStep ? currentStep.next : step;\n\nreturn [{ json: {\n  userId: userRow.id,\n  telegramId: triggerData.message?.from.id || triggerData.callback_query?.from.id,\n  nextStep,\n  context,\n  dailyCalorieTarget,\n  isComplete: nextStep === 'complete'\n} }];"
      },
