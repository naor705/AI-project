        "chatId": "={{ $('Telegram Trigger').item.json.message.from.id }}",
        "text": "👋 Welcome to <b>FitBuddy AI</b>! I'm your personal fitness and nutrition coach powered by AI.\n\nLet's set up your profile — about 2 minutes.\n\n<b>What's your first name?</b>",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "ask-name",
      "name": "Ask Name",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1300, 100],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.from.id }}",
        "text": "Nice to meet you! 💪\n\n<b>How old are you?</b>",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "ask-age",
      "name": "Ask Age",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1300, 220],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.from.id }}",
        "text": "<b>What's your gender?</b>",
        "additionalFields": {
          "parse_mode": "HTML",
          "reply_markup": "{\"inline_keyboard\":[[{\"text\":\"👨 Male\",\"callback_data\":\"gender_male\"},{\"text\":\"👩 Female\",\"callback_data\":\"gender_female\"},{\"text\":\"⚧ Other\",\"callback_data\":\"gender_other\"}]]}"
        }
      },
      "id": "ask-gender",
      "name": "Ask Gender",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1300, 340],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.from.id }}",
        "text": "<b>What's your height in cm?</b>\n\nExample: <code>175</code>",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "ask-height",
      "name": "Ask Height",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1300, 460],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.from.id }}",
        "text": "<b>What's your current weight in kg?</b>\n\nExample: <code>78</code>",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "ask-weight",
      "name": "Ask Weight",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1300, 580],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.from.id }}",
        "text": "<b>How active are you on a typical day?</b>",
        "additionalFields": {
          "parse_mode": "HTML",
          "reply_markup": "{\"inline_keyboard\":[[{\"text\":\"🪑 Sedentary\",\"callback_data\":\"activity_sedentary\"}],[{\"text\":\"🚶 Lightly Active\",\"callback_data\":\"activity_light\"}],[{\"text\":\"🏃 Moderately Active\",\"callback_data\":\"activity_moderate\"}],[{\"text\":\"💪 Active\",\"callback_data\":\"activity_active\"}],[{\"text\":\"🔥 Very Active\",\"callback_data\":\"activity_very_active\"}]]}"
        }
      },
      "id": "ask-activity",
      "name": "Ask Activity",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1300, 700],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.from.id }}",
        "text": "<b>What's your main fitness goal?</b>",
        "additionalFields": {
          "parse_mode": "HTML",
          "reply_markup": "{\"inline_keyboard\":[[{\"text\":\"🎯 Toning & Fat Loss\",\"callback_data\":\"goal_toning\"}],[{\"text\":\"💪 Build Muscle\",\"callback_data\":\"goal_mass\"}],[{\"text\":\"⚖️ Maintenance\",\"callback_data\":\"goal_maintenance\"}]]}"
        }
      },
      "id": "ask-goal",
      "name": "Ask Goal",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1300, 820],
      "credentials": { "telegramApi": { "id": "REPLACE_TELEGRAM_CRED_ID", "name": "FitBuddy Telegram Bot" } }
    },
    {
      "parameters": {
        "jsCode": "const triggerData = $('Telegram Trigger').item.json;\nconst convState = $('Get Conv State').item.json;\nconst userRow = $('Upsert User').item.json;\n\nconst messageText = triggerData.message?.text || '';\nconst callbackData = triggerData.callback_query?.data || '';\nconst inputValue = (messageText || callbackData).trim();\n\nconst step = convState.step;\nlet context = {};\ntry { context = typeof convState.context === 'string' ? JSON.parse(convState.context) : (convState.context || {}); } catch(e) { context = {}; }\n\nconst stepMap = {\n  ask_name:     { key: 'name',           next: 'ask_age' },\n  ask_age:      { key: 'age',            next: 'ask_gender' },\n  ask_gender:   { key: 'gender',         next: 'ask_height', fn: v => v.replace('gender_','') },\n  ask_height:   { key: 'height_cm',      next: 'ask_weight', fn: v => parseFloat(v) },\n  ask_weight:   { key: 'weight_kg',      next: 'ask_activity', fn: v => parseFloat(v) },\n  ask_activity: { key: 'activity_level', next: 'ask_goal', fn: v => v.replace('activity_','') },\n  ask_goal:     { key: 'goal',           next: 'complete', fn: v => v.replace('goal_','') }\n};\n\nconst cur = stepMap[step];\nif (cur) {\n  context[cur.key] = cur.fn ? cur.fn(inputValue) : inputValue;\n}\n\nlet dailyCalorieTarget = null;\nif (context.weight_kg && context.height_cm && context.age && context.gender && context.activity_level && context.goal) {\n  let bmr = context.gender === 'male'\n    ? 10*context.weight_kg + 6.25*context.height_cm - 5*context.age + 5\n    : 10*context.weight_kg + 6.25*context.height_cm - 5*context.age - 161;\n  const mult = {sedentary:1.2,light:1.375,moderate:1.55,active:1.725,very_active:1.9};\n  const tdee = bmr * (mult[context.activity_level] || 1.2);\n  const offset = {toning:-400,mass:300,maintenance:0};\n  dailyCalorieTarget = Math.round(tdee + (offset[context.goal] || 0));\n  context.daily_calorie_target = dailyCalorieTarget;\n}\n\nconst nextStep = cur ? cur.next : step;\n\nreturn [{ json: {\n  userId: userRow.id,\n  telegramId: triggerData.message?.from.id || triggerData.callback_query?.from.id,\n  nextStep,\n  context,\n  dailyCalorieTarget,\n  isComplete: nextStep === 'complete'\n} }];"
      },
      "id": "process-response",
      "name": "Process Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 500]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE conversation_state SET step=$1, context=$2::jsonb, updated_at=now() WHERE user_id=$3 AND flow_id='onboarding'",
        "additionalFields": { "queryParams": "={{ [$json.nextStep, JSON.stringify($json.context), $json.userId].join(',') }}" }
      },
      "id": "update-conv-state",
      "name": "Update Conv State",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [1700, 500],
      "credentials": { "postgres": { "id": "REPLACE_POSTGRES_CRED_ID", "name": "FitBuddy DB" } }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{ $('Process Response').item.json.isComplete }}", "value2": true }]
        }
      },
