      "name": "Onboarding Complete?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1900, 500]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE users SET first_name=$1, age=$2, gender=$3, height_cm=$4, weight_kg=$5, activity_level=$6, goal=$7, daily_calorie_target=$8, onboarding_complete=true, updated_at=now() WHERE id=$9 RETURNING first_name, age, gender, height_cm, weight_kg, activity_level, goal, daily_calorie_target",
        "additionalFields": { "queryParams": "={{ [\n  $('Process Response').item.json.context.name,\n  $('Process Response').item.json.context.age,\n  $('Process Response').item.json.context.gender,\n  $('Process Response').item.json.context.height_cm,\n  $('Process Response').item.json.context.weight_kg,\n  $('Process Response').item.json.context.activity_level,\n  $('Process Response').item.json.context.goal,\n  $('Process Response').item.json.context.daily_calorie_target,\n  $('Process Response').item.json.userId\n].join(',') }}" }
      },
      "id": "save-profile",
      "name": "Save Profile",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [2100, 400],
      "credentials": { "postgres": { "id": "REPLACE_POSTGRES_CRED_ID", "name": "FitBuddy DB" } }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DELETE FROM conversation_state WHERE user_id=$1 AND flow_id='onboarding'",
        "additionalFields": { "queryParams": "={{ $('Process Response').item.json.userId }}" }
      },
      "id": "delete-conv-state",
      "name": "Delete Conv State",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [2300, 400],
      "credentials": { "postgres": { "id": "REPLACE_POSTGRES_CRED_ID", "name": "FitBuddy DB" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Process Response').item.json.telegramId }}",
        "text": "🎉 <b>Profile complete!</b>\n\n📛 Name: {{ $('Save Profile').item.json.first_name }}\n🎂 Age: {{ $('Save Profile').item.json.age }}\n⚖️ Weight: {{ $('Save Profile').item.json.weight_kg }}kg | Height: {{ $('Save Profile').item.json.height_cm }}cm\n🎯 Goal: {{ $('Save Profile').item.json.goal }}\n🔥 Daily target: <b>{{ $('Save Profile').item.json.daily_calorie_target }} kcal</b>\n\n✅ I'll send your daily check-in every morning at <b>8:00 AM</b>.\n\nOr start now with /checkin 💪\n\n<b>Commands:</b>\n/checkin — Daily check-in\n/analyze — Analyze food photo\n/supplements — Supplement advice\n/progress — Weekly report\n/help — All commands",
        "additionalFields": { "parse_mode": "HTML" }
      },
