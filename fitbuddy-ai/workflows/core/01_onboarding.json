        "additionalFields": {
          "parse_mode": "HTML",
          "reply_markup": "{\"inline_keyboard\":[[{\"text\":\"🎯 Toning & Fat Loss\",\"callback_data\":\"goal_toning\"}],[{\"text\":\"💪 Build Muscle (Mass)\",\"callback_data\":\"goal_mass\"}],[{\"text\":\"⚖️ Maintenance\",\"callback_data\":\"goal_maintenance\"}]]}"
