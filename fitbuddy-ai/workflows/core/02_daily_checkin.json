      "webhookId": "fitbuddy-wait-q6"
    },
    {
      "parameters": {
        "chatId": "={{ $('Per User').item.json.telegram_id }}",
        "text": "<b>Question 7/7:</b> 💧 How many glasses of water? (1 glass ≈ 250ml)",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "send-q7",
      "name": "Ask Water",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [3550, 220],
      "credentials": { "telegramApi": { "id": "fitbuddy-telegram-1", "name": "Telegram Bot" } }
    },
    {
      "parameters": {
        "resume": "webhook",
        "webhookSuffix": "={{ `checkin-q7-${$('Per User').item.json.telegram_id}` }}",
        "options": {}
      },
      "id": "wait-q7",
      "name": "Wait Water Answer",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [3750, 220],
      "webhookId": "fitbuddy-wait-q7"
    },
    {
      "parameters": {
        "jsCode": "// Collect all answers from wait nodes\nconst sleepHours = parseFloat($('Wait Sleep Answer').item.json.body?.message?.text || 7);\nconst energyLevel = parseInt($('Wait Energy Answer').item.json.body?.message?.text || 5);\nconst mood = $('Wait Mood Answer').item.json.body?.message?.text || 'okay';\nconst foodDesc = $('Wait Food Answer').item.json.body?.message?.text || 'Not provided';\nconst workoutDesc = $('Wait Workout Answer').item.json.body?.message?.text || 'Rest day';\nconst steps = parseInt($('Wait Steps Answer').item.json.body?.message?.text || 0);\nconst glasses = parseFloat($('Wait Water Answer').item.json.body?.message?.text || 0);\nconst waterMl = glasses * 250;\nconst workoutDone = workoutDesc.toLowerCase() !== 'rest day';\nconst userId = $('Per User').item.json.id;\nconst telegramId = $('Per User').item.json.telegram_id;\nreturn [{ json: { sleepHours, energyLevel, mood, foodDesc, workoutDesc, workoutDone, steps, waterMl, userId, telegramId } }];"
      },
      "id": "collect-answers",
      "name": "Collect Answers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3950, 320]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO daily_logs (user_id, log_date, sleep_hours, energy_level, mood, food_description, workout_done, workout_description, steps, water_ml)\nVALUES ($1, CURRENT_DATE, $2, $3, $4, $5, $6, $7, $8, $9)\nON CONFLICT (user_id, log_date) DO UPDATE SET sleep_hours=EXCLUDED.sleep_hours, energy_level=EXCLUDED.energy_level, mood=EXCLUDED.mood, food_description=EXCLUDED.food_description, workout_done=EXCLUDED.workout_done, workout_description=EXCLUDED.workout_description, steps=EXCLUDED.steps, water_ml=EXCLUDED.water_ml\nRETURNING id",
        "additionalFields": { "queryParams": "={{ [$json.userId, $json.sleepHours, $json.energyLevel, $json.mood, $json.foodDesc, $json.workoutDone, $json.workoutDesc, $json.steps, $json.waterMl].join(',') }}" }
      },
      "id": "insert-log",
      "name": "Insert Daily Log",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [4150, 320],
      "credentials": { "postgres": { "id": "fitbuddy-postgres-1", "name": "FitBuddy DB" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Collect Answers').item.json.telegramId }}",
        "text": "✅ <b>Check-in complete!</b>\n\n🤖 Generating your personalized plan... this takes about 15 seconds ⏳",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "confirm-checkin",
      "name": "Confirm Check-in",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [4350, 320],
      "credentials": { "telegramApi": { "id": "fitbuddy-telegram-1", "name": "Telegram Bot" } }
    },
    {
      "parameters": {
        "workflowId": "3",
        "options": {},
        "workflowInputs": {
          "values": [
            { "name": "user_id", "value": "={{ $('Collect Answers').item.json.userId }}" },
            { "name": "log_date", "value": "={{ new Date().toISOString().split('T')[0] }}" },
            { "name": "telegram_id", "value": "={{ $('Collect Answers').item.json.telegramId }}" }
          ]
        }
      },
      "id": "trigger-ai",
      "name": "Trigger AI Engine",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [4550, 320]
    }
