      "credentials": { "telegramApi": { "id": "fitbuddy-telegram-1", "name": "Telegram Bot" } }
    },
    {
      "parameters": {
        "resume": "webhook",
        "webhookSuffix": "={{ `checkin-q1-${$('Per User').item.json.telegram_id}` }}",
        "options": {}
