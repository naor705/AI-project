      "name": "Ask Energy",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1550, 220],
      "credentials": { "telegramApi": { "id": "fitbuddy-telegram-1", "name": "Telegram Bot" } }
    },
