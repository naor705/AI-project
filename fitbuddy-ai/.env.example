# ─────────────────────────────────
# TELEGRAM
# Required for the bot to function.
# Get a token from @BotFather on Telegram.
# ─────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─────────────────────────────────
# OPENAI (optional — skip for now)
# Only required when the AI engine workflow is active.
# The bot starts fine without it; AI-generated daily
# reports will fail until a key is provided.
# ─────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────
# POSTGRESQL
# These defaults work out-of-the-box locally.
# Change POSTGRES_PASSWORD before any public deployment.
# ─────────────────────────────────
POSTGRES_DB=fitbuddy
POSTGRES_USER=fitbuddy_user
POSTGRES_PASSWORD=fitbuddy_local
POSTGRES_HOST=postgres
POSTGRES_PORT=5433

# ─────────────────────────────────
# N8N
# N8N_ENCRYPTION_KEY: generate with:
#   openssl rand -hex 16
# WEBHOOK_URL: use localhost for local dev.
#   Set to your public HTTPS URL in production.
# ─────────────────────────────────
N8N_PORT=5050
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5050
N8N_ENCRYPTION_KEY=change_me_run_openssl_rand_hex_16
TIMEZONE=UTC

# ─────────────────────────────────
# OPTIONAL: Feature-specific keys
# Add these only when enabling the relevant feature.
# ─────────────────────────────────

# Restaurant Finder feature
# GOOGLE_PLACES_API_KEY=

# Cloudinary (food photo storage)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
