# ─────────────────────────────────
# TELEGRAM
# ─────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─────────────────────────────────
# OPENAI
# ─────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ─────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────
POSTGRES_DB=fitbuddy
POSTGRES_USER=fitbuddy_user
POSTGRES_PASSWORD=change_me_to_something_strong
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─────────────────────────────────
# N8N
# ─────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=https://your-public-domain.com
N8N_ENCRYPTION_KEY=generate_a_random_32_char_string_here

# ─────────────────────────────────
# OPTIONAL: Feature-specific keys
# Add these only when enabling the relevant feature
# ─────────────────────────────────

# Restaurant Finder feature
GOOGLE_PLACES_API_KEY=

# Cloudinary (food photo storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
