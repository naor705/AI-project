# ============================================================
# Short-Form Video Automation MVP — Environment Variables
# ============================================================
# Copy this file to .env for local reference.
# In n8n: set these in Settings → Environment Variables.
# Never commit a .env file with real values to version control.
# ============================================================

# ------------------------------------------------------------
# APIFY — TikTok Trend Scraping
# Used by: "Fetch TikTok Trends (Apify)" node
# ------------------------------------------------------------

# Your Apify API token
# Found at: apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=

# The Apify actor ID for TikTok scraping
# Recommended actors (check Apify Store for availability):
#   clockworks~tiktok-hashtag-search
#   clockworks~free-tiktok-scraper
#   novi~fast-tiktok-api
# Format: username~actor-name (use ~ not /)
APIFY_ACTOR_ID=

# ------------------------------------------------------------
# OPENAI — AI Video Concept Generation
# Used by: "Build OpenAI Request" + "AI Creates Video Idea" nodes
# ------------------------------------------------------------

# Your OpenAI API key
# Found at: platform.openai.com → API keys
# Model used: gpt-4o (change in "Build OpenAI Request" node if needed)
OPENAI_API_KEY=

# ------------------------------------------------------------
# CREATOMATE — Video Rendering
# Used by: "Build Creatomate Request" + "Generate Video" nodes
# ------------------------------------------------------------

# Your Creatomate API key
# Found at: creatomate.com → Settings → API
CREATOMATE_API_KEY=

# The ID of your 9:16 vertical video template
# Found in the template URL after creating and publishing a template
# Format: UUID string (e.g. a1b2c3d4-e5f6-7890-abcd-ef1234567890)
CREATOMATE_TEMPLATE_ID=

# ------------------------------------------------------------
# TELEGRAM — Approval Notifications
# Used by: "Build Telegram Message" + "Send Video to Telegram" nodes
# ------------------------------------------------------------

# Your Telegram bot token
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# The chat ID where approval messages are sent
# Can be a personal chat ID (positive number) or group ID (negative number)
# Get your chat ID by messaging @userinfobot or calling getUpdates
# Example group ID: -1001234567890
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# UPLOAD-POST — TikTok Publishing
# Used by: "Build Upload-Post Request" + "Publish with Upload-Post" nodes
# ------------------------------------------------------------

# Your Upload-Post API key
# Found at: upload-post.com → API settings
UPLOAD_POST_API_KEY=

# Your Upload-Post account or workspace ID
# Found in your Upload-Post dashboard or API settings
UPLOAD_POST_ACCOUNT_ID=

# ------------------------------------------------------------
# GOOGLE SHEETS — Run Logging
# Used by: "Build Sheets Log Row" + "Log to Google Sheets" nodes
# ------------------------------------------------------------

# The ID of your Google Sheet (from the sheet URL)
# URL format: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=

# A valid Google Sheets API OAuth2 access token
# Options:
#   A) Use a service account: generate a token from the service account JSON key
#      gcloud auth print-access-token  (if using gcloud CLI)
#   B) Replace the HTTP Request node with n8n's native Google Sheets node
#      which handles OAuth2 token refresh automatically (recommended)
#   C) For testing: get a short-lived token from Google OAuth2 Playground
#      https://developers.google.com/oauthplayground
#      Scope: https://www.googleapis.com/auth/spreadsheets
GOOGLE_SHEETS_ACCESS_TOKEN=
